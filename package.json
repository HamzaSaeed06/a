{
  "name": "auction-os",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w auction-os-backend\" \"npm run dev -w auction-os-frontend\"",
    "dev:frontend": "npm run dev -w auction-os-frontend",
    "dev:backend": "npm run dev -w auction-os-backend",
    "build": "npm run build -w auction-os-frontend",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.23",
    "mysql2": "^3.22.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "wouter": "^3.9.0"
  }
}
